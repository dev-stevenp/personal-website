---
import "../../styles/global.css";
import Nav from "../../components/Nav.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<html lang="en">
  <head>
    <title>{post.data.title}</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>
  <body>
    <Nav />
    <main class="container mx-auto px-6 py-12 max-w-2xl">
      <a href="/blog" class="text-sm text-gray-400 hover:text-gray-600 transition mb-8 inline-block">
        ← Back to blog
      </a>
      <h1 class="text-2xl font-semibold mt-4 mb-2">{post.data.title}</h1>
      <p class="text-sm text-gray-400 mb-10">
        {post.data.date.toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
        })}
      </p>
      <article class="prose prose-gray max-w-none text-gray-700 leading-relaxed space-y-4">
        <Content />
      </article>
    </main>
  </body>
</html>
