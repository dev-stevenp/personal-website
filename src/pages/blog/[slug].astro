---
import Layout from "../../components/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title}>
  <main class="mx-auto px-6 py-12 max-w-2xl">
    <a href="/blog" class="text-sm text-gray-400 hover:text-gray-600 transition mb-8 inline-block">
      ← Back to blog
    </a>
    <h1 class="text-2xl font-semibold mb-2">{post.data.title}</h1>
    <p class="text-sm text-gray-400 mb-8">
      {post.data.date.toLocaleDateString("en-US", {
        year: "numeric",
        month: "long",
        day: "numeric",
      })}
    </p>
    <div class="border-t border-dotted border-gray-300 mb-8"></div>
    <article class="prose prose-gray max-w-none text-gray-600 leading-relaxed">
      <Content />
    </article>
  </main>
</Layout>
