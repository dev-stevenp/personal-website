---
import "../../styles/global.css";
import Nav from "../../components/Nav.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<html lang="en">
  <head>
    <title>Blog</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>
  <body>
    <Nav />
    <main class="container mx-auto px-6 py-12 max-w-2xl">
      <h1 class="text-2xl font-semibold mb-10">Blog</h1>
      <ul class="space-y-4">
        {posts.map((post) => (
          <li>
            <a
              href={`/blog/${post.id}`}
              class="group block border border-gray-200 rounded-xl px-5 py-4 hover:border-gray-400 transition-colors"
            >
              <div class="flex items-baseline justify-between gap-4">
                <span class="text-base font-medium group-hover:underline underline-offset-4">
                  {post.data.title}
                </span>
                <span class="text-sm text-gray-400 shrink-0">
                  {post.data.date.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </span>
              </div>
              {post.data.description && (
                <p class="mt-1 text-sm text-gray-500">{post.data.description}</p>
              )}
            </a>
          </li>
        ))}
      </ul>
    </main>
  </body>
</html>
